# Example nginx config for fronting nimbusfs with proxy-based auth
# (e.g. Authelia, Keycloak via oauth2-proxy, etc). Adjust the auth_request
# block for whichever auth provider you're using; the headers below are
# what nimbusfs actually requires.
server {
    listen 443 ssl;
    server_name files.example.com;

    location / {
        # Your auth provider sets $remote_user after validating the request,
        # e.g. via auth_request to Authelia/oauth2-proxy. Configure that
        # separately — this just shows the headers nimbusfs needs from it.
        proxy_set_header X-Remote-User $remote_user;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;

        proxy_pass http://127.0.0.1:8080;
    }
}
